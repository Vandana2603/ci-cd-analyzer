# Copy this to .env and fill in your values
OPENAI_API_KEY=sk-...         # Optional - leave blank for mock analysis
DATABASE_URL=sqlite+aiosqlite:///./cicd_analyzer.db
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=gpt-3.5-turbo
MAX_CHUNK_SIZE=2000
TOP_K_SIMILAR=3
DEBUG=true
